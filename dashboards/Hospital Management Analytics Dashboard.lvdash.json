{
  "datasets": [
    {
      "name": "age_group_analysis",
      "displayName": "Age Group Analysis",
      "queryLines": [
        "SELECT\n",
        "  age_group,\n",
        "  gender,\n",
        "  patient_count\n",
        "FROM\n",
        "  dbutils_catalog.gold_hospital.age_group_analysis\n",
        "ORDER BY\n",
        "  age_group,\n",
        "  gender"
      ]
    },
    {
      "name": "payment_distribution",
      "displayName": "Payment Distribution",
      "queryLines": [
        "SELECT\n",
        "  payment_method,\n",
        "  total_transactions\n",
        "FROM\n",
        "  dbutils_catalog.gold_hospital.payment_analysis"
      ]
    },
    {
      "name": "kpi_metrics",
      "displayName": "KPI Metrics",
      "queryLines": [
        "SELECT\n",
        "  COUNT(*) as total_patients,\n",
        "  ROUND(AVG(age), 1) as average_age,\n",
        "  SUM(bill_amount) as total_revenue\n",
        "FROM\n",
        "  dbutils_catalog.silver_hospital.patients_clean"
      ]
    },
    {
      "name": "city_distribution",
      "displayName": "City Distribution",
      "queryLines": [
        "SELECT\n",
        "  city,\n",
        "  patient_count\n",
        "FROM\n",
        "  dbutils_catalog.gold_hospital.city_patient_distribution\n",
        "ORDER BY\n",
        "  patient_count DESC"
      ]
    },
    {
      "name": "disease_analysis",
      "displayName": "Disease Analysis",
      "queryLines": [
        "SELECT\n",
        "  disease,\n",
        "  patient_count\n",
        "FROM\n",
        "  dbutils_catalog.gold_hospital.disease_analysis\n",
        "ORDER BY\n",
        "  patient_count DESC"
      ]
    },
    {
      "name": "top_disease",
      "displayName": "Top Disease",
      "queryLines": [
        "SELECT\n",
        "  disease,\n",
        "  patient_count\n",
        "FROM\n",
        "  dbutils_catalog.gold_hospital.disease_analysis\n",
        "ORDER BY\n",
        "  patient_count DESC\n",
        "LIMIT 1"
      ]
    },
    {
      "name": "monthly_admissions",
      "displayName": "Monthly Admissions",
      "queryLines": [
        "SELECT\n",
        "  MONTH(admission_date) as admission_month,\n",
        "  COUNT(*) as patient_count\n",
        "FROM\n",
        "  dbutils_catalog.silver_hospital.patients_clean\n",
        "GROUP BY\n",
        "  MONTH(admission_date)\n",
        "ORDER BY\n",
        "  admission_month"
      ]
    },
    {
      "name": "city_bill_analysis",
      "displayName": "City Bill Analysis",
      "queryLines": [
        "SELECT\n",
        "  city,\n",
        "  average_bill\n",
        "FROM\n",
        "  dbutils_catalog.gold_hospital.city_bill_analysis\n",
        "ORDER BY\n",
        "  average_bill DESC"
      ]
    },
    {
      "name": "gender_distribution",
      "displayName": "Gender Distribution",
      "queryLines": [
        "SELECT\n",
        "  gender,\n",
        "  total_patients\n",
        "FROM\n",
        "  dbutils_catalog.gold_hospital.patient_demographics"
      ]
    },
    {
      "name": "hospital_performance",
      "displayName": "Hospital Performance",
      "queryLines": [
        "SELECT\n",
        "  hospital_name,\n",
        "  patient_count,\n",
        "  avg_bill\n",
        "FROM\n",
        "  dbutils_catalog.gold_hospital.hospital_analysis\n",
        "ORDER BY\n",
        "  patient_count DESC"
      ]
    }
  ],
